# Copy to .env and fill in values (never commit .env)
# All secrets are managed via Doppler — see ops/environment.md

# ─── AI / LLM ───────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Notifications ──────────────────────────────────────────
DISCORD_WEBHOOK=

# ─── Automation ─────────────────────────────────────────────
N8N_HOST=
N8N_TK22_PR_WEBHOOK=

# ─── Blockchain / Helius ────────────────────────────────────
HELIUS_API_KEY=
HELIUS_RPC_URL=

# ─── Database / Supabase ────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ─── Control Runtime ────────────────────────────────────────
CONTROL_API_PORT=5000
CONTROL_API_HOST=0.0.0.0
FLASK_ENV=development

# ─── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ─── Environment ────────────────────────────────────────────
# Values: development | staging | production
APP_ENV=development
LOG_LEVEL=INFO
