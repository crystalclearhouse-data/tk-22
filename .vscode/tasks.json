{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Webhook Receiver",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}/backend/webhook_receiver.py"
      ],
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "showReuseMessage": false
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": false
      }
    },
    {
      "label": "Test Job Webhook",
      "type": "shell",
      "command": "curl",
      "args": [
        "-X",
        "POST",
        "http://localhost:5000/webhook/github-job",
        "-H",
        "Content-Type: application/json",
        "-d",
        "@${workspaceFolder}/backend/test-job-payload.json",
        "-v"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": false
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "problemMatcher": []
    },
    {
      "label": "Check Webhook Health",
      "type": "shell",
      "command": "curl",
      "args": [
        "-X",
        "GET",
        "http://localhost:5000/health",
        "-v"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": false
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "problemMatcher": []
    }
  ]
}
